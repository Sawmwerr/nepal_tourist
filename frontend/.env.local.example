# Copy this file to .env.local and fill in your project values.
# Never commit .env.local.

# ─── Supabase server-side booking database ────────────────────────────────────
# Dashboard → Project Settings → API

# Base project URL only. Example: https://your-project-ref.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# Service-role key — SECRET.
# Used only by Next.js server actions/API routes. Never expose in browser code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Email notifications via Resend ───────────────────────────────────────────
# Get your API key at https://resend.com
RESEND_API_KEY=re_your_api_key

# Verified sender address in Resend domain settings
FROM_EMAIL=booking@yourdomain.com

# ─── Supabase browser/customer/admin auth ─────────────────────────────────────
# Public anon key is safe for browser auth. Do NOT put the service-role key here.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Supabase Auth URL settings ───────────────────────────────────────────────
# Dashboard → Authentication → URL Configuration
# Local Site URL: http://localhost:3000
# Local Redirect URL: http://localhost:3000/**
# For local testing, disable email confirmation or manually confirm test users.

# ─── Setup checklist ──────────────────────────────────────────────────────────
# 1. Create a Supabase project at https://supabase.com
# 2. Run all SQL migrations in backend/supabase/migrations/ in numeric order
# 3. Configure Supabase Auth URL settings above
# 4. Create a Resend account and verify a sending domain if email is needed
# 5. Fill in all variables above in .env.local
# 6. Restart the dev server after changing env values
