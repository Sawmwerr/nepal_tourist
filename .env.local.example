# ─── Supabase ─────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your project values.
# Dashboard > Project Settings > API

# Project URL (safe to expose — not a secret)
SUPABASE_URL=https://your-project-ref.supabase.co

# Service-role key — NEVER commit or expose to the browser.
# Used ONLY in server actions / API routes (bypasses Row-Level Security).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Email notifications ──────────────────────────────────────────────────────
# Get your API key at https://resend.com (free tier: 100 emails/day)
RESEND_API_KEY=re_...

# Verified sender address in your Resend domain settings
FROM_EMAIL=booking@yourdomain.com

# ─── Setup checklist ──────────────────────────────────────────────────────────
# 1. Create a Supabase project at https://supabase.com
# 2. Run scripts/migrate.sql in Dashboard > SQL Editor
# 3. Create a Resend account and verify a sending domain
# 4. Fill in all variables above in .env.local
# 5. Restart the dev server (Next.js reads .env.local on startup)
